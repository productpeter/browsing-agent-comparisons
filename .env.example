# Tabstack — required for paired modes (markdown, generate, automate, research).
# Omit for Firecrawl-only modes (search, crawl, map) if you only use those.
TABSTACK_API_KEY=

# Optional: cap Tabstack automate SSE (milliseconds). Default 60000. Use 0 for no limit.
# TABSTACK_AUTOMATE_TIMEOUT_MS=
# Same value for the Run button countdown (optional; defaults to 60s if unset):
# NEXT_PUBLIC_TABSTACK_AUTOMATE_TIMEOUT_MS=

# Alternative env name supported by the app:
# TABS_API_KEY=

# Firecrawl — create a key at https://firecrawl.dev/
# Not required for automate mode (Tabstack-only in this app).
FIRECRAWL_API_KEY=
